---
import PageLayout from '@/layouts/PageLayout.astro'
import GalleryList from '@/components/gallery/GalleryList.astro'
import PostPagination from '@/components/post/PostPagination.astro'
import Highlight from '@/components/Highlight.astro'
import { getSortedGalleryPaginated } from '@/utils/content'
import appConfig from '@/config.json'

const perPage = appConfig.gallery.perPage
const { data, totalPages, currentPage } = await getSortedGalleryPaginated(1, perPage)
const getPageUrl = (page: number) => {
  if (page === 1) return '/gallery'
  return `/gallery/page/${page}`
}
---

<PageLayout>
  <div class="max-w-[1100px] px-4 md:px-8 py-20 mx-auto">
    <div class="mb-8">
      <h1 class="text-4xl font-bold">
        <Highlight>画廊</Highlight>
      </h1>
      <p>探索我的作品和创意集合</p>
    </div>

    <GalleryList galleries={data} />

    {
      totalPages > 1 && (
        <div class="mt-12">
          <PostPagination current={currentPage} total={totalPages} getPageUrl={getPageUrl} />
        </div>
      )
    }
  </div>
</PageLayout>
