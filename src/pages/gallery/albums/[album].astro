---
import type { GetStaticPaths } from 'astro'
import PageLayout from '@/layouts/PageLayout.astro'
import GalleryList from '@/components/gallery/GalleryList.astro'
import PostPagination from '@/components/post/PostPagination.astro'
import { getAllAlbums, getSortedGalleryByAlbumPaginated } from '@/utils/content'
import appConfig from '@/config.json'

export const getStaticPaths = (async () => {
  const allAlbums = await getAllAlbums()

  return allAlbums.map((album) => ({
    params: { album: album.slug },
    props: { albumName: album.name },
  }))
}) satisfies GetStaticPaths

interface Props {
  albumName: string
}

const { album } = Astro.params
const { albumName } = Astro.props

if (!album) {
  return Astro.redirect('/gallery')
}

const perPage = appConfig.gallery.perPage
const { data, totalPages, currentPage, total } = await getSortedGalleryByAlbumPaginated(album, 1, perPage)

if (data.length === 0) {
  return Astro.redirect('/gallery')
}

const getPageUrl = (page: number) => {
  if (page === 1) return `/gallery/albums/${album}`
  return `/gallery/albums/${album}/page/${page}`
}
---

<PageLayout>
  <div class="max-w-[1100px] px-4 md:px-8 py-20 mx-auto">
    <div class="mb-12">
      <a href="/gallery" class="inline-flex items-center text-accent hover:underline mb-4">
        ← 返回画廊
      </a>
      <h1 class="text-4xl font-bold text-primary mb-2">{albumName}</h1>
      <p class="text-gray-600 dark:text-gray-400">
        共 {total} 个条目
      </p>
    </div>

    <GalleryList galleries={data} />

    {
      totalPages > 1 && (
        <div class="mt-12">
          <PostPagination current={currentPage} total={totalPages} getPageUrl={getPageUrl} />
        </div>
      )
    }
  </div>
</PageLayout>
