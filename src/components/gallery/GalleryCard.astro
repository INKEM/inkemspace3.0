---
import { getThumbnailUrl } from '@/utils/image'
import type { CollectionEntry } from 'astro:content'

interface Props {
  gallery: CollectionEntry<'gallery'>
}

const { gallery } = Astro.props
const { title, album, images, videos, date } = gallery.data

// 获取第一张图片作为封面，或第一个视频封面
const coverImage = images[0]?.url || videos[0]?.cover
const thumbnailUrl = coverImage ? getThumbnailUrl(coverImage, 400, 300) : null

// 计算总的媒体数量
const totalMedia = (images?.length || 0) + (videos?.length || 0)

// 格式化日期
const formattedDate = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})
---

<a href={`/gallery/${gallery.slug}`} class="gallery-card group">
  <div class="relative w-full overflow-hidden rounded-lg bg-gray-200">
    {thumbnailUrl ? (
      <img
        src={thumbnailUrl}
        alt={title}
        class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-110"
      />
    ) : (
      <div class="flex h-48 w-full items-center justify-center bg-gradient-to-br from-gray-300 to-gray-400">
        <span class="text-gray-600">No Media</span>
      </div>
    )}
    <div class="absolute inset-0 bg-black/0 transition-all duration-300 group-hover:bg-black/20"></div>

    {/* Media Count Badge */}
    <div class="absolute bottom-2 right-2 rounded-full bg-black/70 px-3 py-1 text-sm font-medium text-white">
      {totalMedia} items
    </div>
  </div>

  <div class="mt-3 space-y-1">
    <h3 class="line-clamp-2 font-semibold text-primary group-hover:text-accent">
      {title}
    </h3>
    <p class="text-sm text-gray-600 dark:text-gray-400">{album}</p>
    <p class="text-xs text-gray-500 dark:text-gray-500">{formattedDate}</p>
  </div>
</a>

<style is:global>
  .gallery-card {
    @apply flex flex-col gap-2 transition-all duration-300;
  }
</style>
